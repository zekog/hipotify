<resources>
    <!-- The root keys for TrustTokenService. The keys are in COSE_Key (RFC 9052) format and then
      encoded with BASE64.

      It should be updated in accordance with root keys used by the TrustTokenService. It's highly
      recommended to rotate the root keys periodically. To ensure the smooth operation of existing
      devices, it's also recommended to front-load several root keys.

      If not already present in resource overlay, please add
      vendor_required_trust_token_roots.xml (matching this file) in vendor overlay.
    -->
    <string-array translatable="false" name="vendor_required_trust_token_roots">
    </string-array>

    <!-- The timestamp in seconds the keys are provisioned. -->
    <integer name="vendor_required_trust_token_roots_timestamp">0</integer>
</resources>
