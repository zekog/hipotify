<com.android.internal.widget.SingleMetricNotificationFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/metric_view_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:gravity="top" >

        <TextView
            android:id="@+id/metric_label_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:maxLines="1"
            style="@style/NotificationExpandedSingleMetricLabel"
            />

        <LinearLayout
            android:id="@+id/metric_value_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:orientation="vertical">
                <com.android.internal.widget.NotificationMetricAdaptiveTextView
                    android:id="@+id/metric_value_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/NotificationExpandedSingleMetricValue"
                    />

                <com.android.internal.widget.NotificationMetricAdaptiveChronometer
                    android:id="@+id/metric_chronometer_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    style="@style/NotificationExpandedSingleMetricValue"
                    />

        </LinearLayout>

</com.android.internal.widget.SingleMetricNotificationFrameLayout>
