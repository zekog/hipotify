<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/dialog_padding_material">

    <ImageView
        android:id="@+id/app_lock_dialog_lock_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_lock_bold"
        android:tint="@color/materialColorPrimary" />

    <TextView
        android:fontFamily="@*android:string/config_headlineFontFamily"
        android:id="@+id/app_lock_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dialog_title_divider_material"
        android:text="@string/app_lock_add_screen_lock_title"
        android:textAppearance="?android:attr/textAppearanceLarge" />

    <TextView
        android:id="@+id/app_lock_dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dialog_title_divider_material"
        android:text="@string/app_lock_add_screen_lock_message"
        android:textColor="@color/materialColorOnSurfaceVariant"
        android:lineHeight="@dimen/app_lock_line_height_small"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textAlignment="viewStart"
        android:gravity="start" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dialog_padding_material"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <Button
            android:id="@+id/app_lock_dialog_cancel_button"
            style="@android:style/Widget.DeviceDefault.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/app_lock_btn_pill_outline"
            android:layout_marginEnd="@dimen/dialog_title_divider_material"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/materialColorPrimary" />

        <Button
            android:id="@+id/app_lock_dialog_add_screen_lock_button"
            style="@android:style/Widget.DeviceDefault.Button.Colored"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/app_lock_btn_pill_background"
            android:paddingStart="@dimen/select_dialog_padding_start_material"
            android:paddingEnd="@dimen/select_dialog_padding_start_material"
            android:text="@string/app_lock_add_screen_lock_button_text"
            android:textAllCaps="false"
            android:textColor="@color/materialColorOnPrimary" />
    </LinearLayout>
</LinearLayout>
