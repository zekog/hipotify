<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_bar_latest_event_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipChildren="false"
    android:tag="metric"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <com.android.internal.widget.PromotedSingleMetricNotificationFrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="top"
            >

            <include layout="@layout/notification_2025_template_header" />

            <!-- Note: the top margin is being set in code based on the estimated space needed for
            the header text. -->
            <LinearLayout
                android:id="@+id/notification_main_column"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/notification_2025_content_margin_start"
                android:layout_marginEnd="@dimen/notification_2025_margin"
                android:orientation="vertical"
                >
                <com.android.internal.widget.ImageFloatingTextView
                    style="@style/NotificationExpandedSingleMetricLabel"
                    android:id="@+id/metric_label_0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:minHeight="@dimen/notification_text_height"
                    android:ellipsize="end"
                    android:fadingEdge="horizontal"
                    android:gravity="top"
                    android:maxLines="1"
                    android:textAlignment="viewStart"
                    />
            </LinearLayout>

            <!--Metric Value and Chronometer -->
            <FrameLayout
                android:id="@+id/metric_value_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingRight="@dimen/notification_2025_margin"
                android:layout_marginTop="@dimen/notification_2025_right_icon_vertical_margin">
                <com.android.internal.widget.NotificationMetricAdaptiveTextView
                    android:id="@+id/metric_value_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="top|end"
                    style="@style/NotificationExpandedSingleMetricValue"
                    />
                <com.android.internal.widget.NotificationMetricAdaptiveChronometer
                    android:id="@+id/metric_chronometer_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:gravity="top|end"
                    style="@style/NotificationExpandedSingleMetricValue"
                    />
            </FrameLayout>
        </com.android.internal.widget.PromotedSingleMetricNotificationFrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginTop="-16dp">
            <include layout="@layout/notification_2025_action_list" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>